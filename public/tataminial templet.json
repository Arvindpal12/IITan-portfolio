{"content":[{"id":"215ffb19","settings":{"flex_direction":"column","background_background":"classic","background_color":"#C8FF31","padding":{"unit":"px","top":"100","right":"0","bottom":"100","left":"0","isLinked":false},"hover_parallax":[{"layer_position_vr":{"unit":"%","size":30},"layer_position_hr":{"unit":"%","size":40},"_id":"87b0441"},{"layer_position_vr":{"unit":"%","size":60},"layer_position_hr":{"unit":"%","size":20},"_id":"ab9b39e"}]},"elements":[{"id":"6f9fd217","settings":{"content_width":"full","hover_parallax":[{"layer_position_vr":{"unit":"%","size":30},"layer_position_hr":{"unit":"%","size":40},"_id":"e2ab2c7"},{"layer_position_vr":{"unit":"%","size":60},"layer_position_hr":{"unit":"%","size":20},"_id":"d0fca3d"}]},"elements":[{"id":"2d1331e8","settings":{"title":"Brands That <span style=\"background: #fff; padding: 0px 10px; border-radius: 20px;\">Trust us.<\/span>","typography_typography":"custom","typography_font_family":"Poppins","typography_font_size":{"unit":"px","size":60,"sizes":[]},"typography_font_weight":"800","title_color":"#000000","typography_font_size_mobile":{"unit":"px","size":70,"sizes":[]},"eael_vto_writing_gradient_color_repeater":[{"eael_vto_writing_gradient_color":"#7C62FF","eael_vto_writing_gradient_color_location":{"unit":"%","size":50},"_id":"e82607c"},{"eael_vto_writing_gradient_color":"#FF6464","eael_vto_writing_gradient_color_location":{"unit":"%","size":90},"_id":"5f47a02"}]},"elements":[],"isInner":false,"widgetType":"heading","elType":"widget"}],"isInner":true,"elType":"container"},{"id":"30789f63","settings":{"content_width":"full","overflow":"hidden","background_background":"classic","background_color":"#FFFFFF","border_radius":{"unit":"px","top":"40","right":"40","bottom":"40","left":"40","isLinked":true},"padding":{"unit":"px","top":"40","right":"20","bottom":"40","left":"20","isLinked":false},"hover_parallax":[{"layer_position_vr":{"unit":"%","size":30},"layer_position_hr":{"unit":"%","size":40},"_id":"332abf2"},{"layer_position_vr":{"unit":"%","size":60},"layer_position_hr":{"unit":"%","size":20},"_id":"e8d2212"}]},"elements":[{"id":"7e8f3dbf","settings":{"html":"    <style>\r\n        \/* --- 1. Base Setup --- *\/\r\n     \r\n\r\n        .body-div {\r\n            display: flex;\r\n            justify-content: center;\r\n            align-items: center;\r\n \r\n            background-color: #fff;\r\n        }\r\n\r\n        .testimonial-container {\r\n            width: 100%;\r\n            max-width: 900px;\r\n            text-align: center;\r\n            padding: 40px 20px;\r\n        }\r\n\r\n        \/* --- 2. Text Area --- *\/\r\n        .review-box {\r\n            position: relative;\r\n            max-width: 600px;\r\n            margin: 0 auto auto auto;\r\n            min-height: 120px;\r\n        }\r\n\r\n        .quote-icon {\r\n            font-size: 5rem;\r\n            font-family: serif;\r\n            color: #111;\r\n            position: absolute;\r\n            top: -30px;\r\n            left: -50px;\r\n            line-height: 1;\r\n        }\r\n\r\n        .review-text {\r\n            font-size: 1.15rem;\r\n            line-height: 1.6;\r\n            color: #333;\r\n            transition: opacity 0.4s ease, transform 0.4s ease;\r\n        }\r\n\r\n        .review-text.hidden {\r\n            opacity: 0;\r\n            transform: translateY(10px);\r\n        }\r\n\r\n        \/* --- 3. The Scroll Wrapper (Calculated for 5.5 items) --- *\/\r\n        .avatar-scroll-window {\r\n            \/* \r\n               CALCULATION LOGIC:\r\n               1 Active Item (~210px) \r\n               + 4 Inactive Items (4 * 70px = 280px) \r\n               + 0.5 Inactive Item (35px) \r\n               + Gaps (~15px each)\r\n               = Approx 550px max-width creates the cut-off effect.\r\n            *\/\r\n            max-width: 550px;\r\n            margin: 0 auto;\r\n            overflow-x: auto;\r\n            padding: 20px 0;\r\n            \/* Space for shadows *\/\r\n\r\n            \/* Hide Scrollbars *\/\r\n            scrollbar-width: none;\r\n            -ms-overflow-style: none;\r\n\r\n            \/* Smooth momentum scrolling on mobile *\/\r\n            -webkit-overflow-scrolling: touch;\r\n        }\r\n\r\n        .avatar-scroll-window::-webkit-scrollbar {\r\n            display: none;\r\n        }\r\n\r\n        .avatar-list {\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 15px;\r\n            width: max-content;\r\n            \/* Forces the list to be wide, enabling scroll *\/\r\n            padding: 0 10px;\r\n            \/* Little buffer on edges *\/\r\n        }\r\n\r\n        \/* --- 4. Avatar Styling --- *\/\r\n        .avatar-item {\r\n            display: flex;\r\n            align-items: center;\r\n            background: #f4f4f4;\r\n            border-radius: 60px;\r\n            padding: 5px;\r\n            \/* Creates the circle size *\/\r\n            cursor: pointer;\r\n            transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);\r\n            \/* Smooth expansion *\/\r\n            flex-shrink: 0;\r\n            \/* Prevents items from squishing *\/\r\n            border: 1px solid transparent;\r\n        }\r\n\r\n        .avatar-item img {\r\n            width: 50px;\r\n            height: 50px;\r\n            border-radius: 50%;\r\n            object-fit: cover;\r\n            filter: grayscale(100%);\r\n            transition: transform 0.3s ease, filter 0.3s ease;\r\n        }\r\n\r\n        \/* Hover effect (Inactive) *\/\r\n        .avatar-item:not(.active):hover {\r\n            background: #e0e0e0;\r\n        }\r\n\r\n        .avatar-item:not(.active):hover img {\r\n            transform: scale(1.1);\r\n            filter: grayscale(0%);\r\n        }\r\n\r\n        \/* --- 5. Active State (The Pill) --- *\/\r\n        .avatar-item.active {\r\n            background-color: #1a1a1a;\r\n            padding-right: 25px;\r\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);\r\n        }\r\n\r\n        .avatar-item.active img {\r\n            filter: grayscale(0%);\r\n            border: 2px solid #fff;\r\n            transform: scale(1.05);\r\n        }\r\n\r\n        \/* Text Details *\/\r\n        .avatar-details {\r\n            max-width: 0;\r\n            overflow: hidden;\r\n            opacity: 0;\r\n            white-space: nowrap;\r\n            margin-left: 0;\r\n            display: flex;\r\n            flex-direction: column;\r\n            text-align: left;\r\n            transition: all 0.5s ease;\r\n        }\r\n\r\n        .avatar-item.active .avatar-details {\r\n            max-width: 200px;\r\n            \/* Width expands here *\/\r\n            margin-left: 12px;\r\n            opacity: 1;\r\n        }\r\n\r\n        .avatar-name {\r\n            color: #fff;\r\n            font-size: 0.9rem;\r\n            font-weight: 600;\r\n        }\r\n\r\n        .avatar-role {\r\n            color: #aaa;\r\n            font-size: 0.75rem;\r\n        }\r\n\r\n        \/* Mobile Adjustment: Show fewer items (3.5) on small screens *\/\r\n        @media (max-width: 600px) {\r\n            .avatar-scroll-window {\r\n                max-width: 100%;\r\n                \/* Use full width *\/\r\n                padding-left: 20px;\r\n                \/* Offset start *\/\r\n            }\r\n\r\n            .quote-icon {\r\n                position: static;\r\n                display: block;\r\n                text-align: center;\r\n                margin-bottom: 15px;\r\n            }\r\n        }\r\n        \r\n        .rating-pill {\r\n    display: inline-block;\r\n    background: #e9e9e9;\r\n    border-radius: 333px;\r\n    padding: 6px 14px;\r\n    font-size: 0.9rem;\r\n    letter-spacing: 2px;\r\n    color: #111;\r\n    margin-bottom: 20px;\r\n}\r\n    <\/style>\r\n\r\n\r\n<div class=\"body-div\">\r\n\r\n    <div class=\"testimonial-container\">\r\n\r\n        <div class=\"review-box\">\r\n    <span class=\"quote-icon\">\u201c<\/span>\r\n\r\n    <div class=\"rating-pill\" id=\"rating-pill\"><\/div>\r\n\r\n    <p class=\"review-text\" id=\"review-text\"><\/p>\r\n<\/div>\r\n\r\n        <!-- The Window constraints the view to 5.5 items -->\r\n        <div class=\"avatar-scroll-window\" id=\"scroll-window\">\r\n            <div class=\"avatar-list\" id=\"avatar-list\">\r\n                <!-- Avatars Injected via JS -->\r\n            <\/div>\r\n        <\/div>\r\n    <\/div>\r\n\r\n    <script>\r\n        \/\/ Data Source (10 items to ensure scrolling is necessary)\r\n        \/\/ const testimonials = [\r\n        \/\/     { id: 1, name: \"Lester Walsh\", role: \"Professional rider\", review: \"I am very happy with the bike. It's not only a lightweight bike which can be ridden after the battery dies if needed, but a fast bike due to its geometry.\", image: \"https:\/\/images.unsplash.com\/photo-1507003211169-0a1dd7228f2d?w=100&q=80\" },\r\n        \/\/     { id: 2, name: \"Sarah Jenkins\", role: \"Daily Commuter\", review: \"The battery life is absolutely game-changing for my daily commute. I used to arrive at work sweaty and tired, but now I breeze through traffic.\", image: \"https:\/\/images.unsplash.com\/photo-1494790108377-be9c29b29330?w=100&q=80\" },\r\n        \/\/     { id: 3, name: \"Michael Chen\", role: \"Tech Enthusiast\", review: \"I've tried five different e-bikes in this price range, and the motor assistance on this one is the smoothest by far. It feels natural.\", image: \"https:\/\/images.unsplash.com\/photo-1500648767791-00dcc994a43e?w=100&q=80\" },\r\n        \/\/     { id: 4, name: \"Emily Davis\", role: \"Weekend Explorer\", review: \"Took this off-road last weekend and it handled gravel paths surprisingly well for a road-geometry bike. The build quality is solid.\", image: \"https:\/\/images.unsplash.com\/photo-1438761681033-6461ffad8d80?w=100&q=80\" },\r\n        \/\/     { id: 5, name: \"David Ross\", role: \"Urban Planner\", review: \"From an urban mobility standpoint, this is the future. Compact enough to bring into my apartment, but powerful enough for hills.\", image: \"https:\/\/images.unsplash.com\/photo-1472099645785-5658abf4ff4e?w=100&q=80\" },\r\n        \/\/     { id: 6, name: \"Jessica Lee\", role: \"Designer\", review: \"The aesthetics are just stunning. I get stopped at lights constantly by people asking what brand it is. It's a true piece of art.\", image: \"https:\/\/images.unsplash.com\/photo-1544005313-94ddf0286df2?w=100&q=80\" },\r\n        \/\/     { id: 7, name: \"Tom Wilson\", role: \"Coach\", review: \"I love that I can adjust the assistance level. I can turn it off for a workout or crank it up when my legs are shot.\", image: \"https:\/\/images.unsplash.com\/photo-1506794778202-cad84cf45f1d?w=100&q=80\" },\r\n        \/\/     { id: 8, name: \"Olivia Brown\", role: \"Architect\", review: \"Precision engineering at its finest. Every weld, every bolt feels intentional. It's rare to see this level of detail.\", image: \"https:\/\/images.unsplash.com\/photo-1534528741775-53994a69daeb?w=100&q=80\" },\r\n        \/\/     { id: 9, name: \"Daniel Kim\", role: \"Student\", review: \"Best investment I made for college. It saves me so much on Uber rides and the detachable battery makes charging in dorms easy.\", image: \"https:\/\/images.unsplash.com\/photo-1519345182560-3f2917c472ef?w=100&q=80\" },\r\n        \/\/     { id: 10, name: \"Sophia Martinez\", role: \"Photographer\", review: \"The smooth ride allows me to carry my camera gear without worrying about vibrations damaging the lenses. Highly recommended.\", image: \"https:\/\/images.unsplash.com\/photo-1531123897727-8f129e1688ce?w=100&q=80\" }\r\n        \/\/ ];\r\n        \r\n        const ratingEl = document.getElementById('rating-pill');\r\n        \r\n      const testimonials = [\r\n    {\r\n        id: 1,\r\n        name: \"Ananya N.\",\r\n        role: \"Founder, Women's D2C Fashion Brand\",\r\n        rating: 5,\r\n        review: \"MKTG Solution completely transformed our Meta ads performance. We went from 2x ROAS to consistently hitting 7-8x in under 3 months. Their approach to creative testing is unlike anything we'd seen from previous agencies.\",\r\n        image: \"https:\/\/ui-avatars.com\/api\/?name=AN&background=111&color=fff\"\r\n    },\r\n    {\r\n        id: 2,\r\n        name: \"Rohit K.\",\r\n        role: \"Co-Founder, Skincare Brand\",\r\n        rating: 4,\r\n        review: \"What I love most is the transparency. I know exactly where every rupee is going and what it's returning. The weekly reports are clear, honest, and actionable \u2014 not a flood of impressive-sounding numbers that don't mean anything.\",\r\n        image: \"https:\/\/ui-avatars.com\/api\/?name=RK&background=111&color=fff\"\r\n    },\r\n    {\r\n        id: 3,\r\n        name: \"Priya S.\",\r\n        role: \"Director, Health & Wellness Brand\",\r\n        rating: 5,\r\n        review: \"We'd burned money with two agencies before MKTG. They audited our account in week one and found we were wasting 40% of our budget on the wrong audience segments. Turned that around fast \u2014 our CAC dropped by half within 6 weeks.\",\r\n        image: \"https:\/\/ui-avatars.com\/api\/?name=PS&background=111&color=fff\"\r\n    }\r\n];\r\n\r\n\r\n        const avatarListEl = document.getElementById('avatar-list');\r\n        const reviewTextEl = document.getElementById('review-text');\r\n\r\n        let currentIndex = 0;\r\n\r\n        function init() {\r\n            renderAvatars();\r\n            updateTestimonial(0);\r\n        }\r\n\r\n        function renderAvatars() {\r\n            avatarListEl.innerHTML = testimonials.map((t, index) => `\r\n                <div class=\"avatar-item ${index === 0 ? 'active' : ''}\" \r\n                     id=\"avatar-${index}\"\r\n                     onclick=\"handleAvatarClick(${index})\">\r\n                    <img src=\"${t.image}\" alt=\"${t.name}\">\r\n                    <div class=\"avatar-details\">\r\n                        <span class=\"avatar-name\">${t.name}<\/span>\r\n                        <span class=\"avatar-role\">${t.role}<\/span>\r\n                    <\/div>\r\n                <\/div>\r\n            `).join('');\r\n        }\r\n\r\n        window.handleAvatarClick = (index) => {\r\n            if (index === currentIndex) return;\r\n\r\n            \/\/ 1. Toggle Active Classes\r\n            const currentActive = document.querySelector('.avatar-item.active');\r\n            const newActive = document.getElementById(`avatar-${index}`);\r\n\r\n            if (currentActive) currentActive.classList.remove('active');\r\n            newActive.classList.add('active');\r\n\r\n            \/\/ 2. Animate Text Swap\r\n            updateTestimonial(index);\r\n\r\n            currentIndex = index;\r\n\r\n            \/\/ 3. Scroll Into View Logic\r\n            \/\/ 'inline: center' puts the clicked item in the middle of our 5.5 view window\r\n            newActive.scrollIntoView({\r\n                behavior: 'smooth',\r\n                block: 'nearest',\r\n                inline: 'center'\r\n            });\r\n        };\r\n\r\n       function updateTestimonial(index) {\r\n    reviewTextEl.classList.add('hidden');\r\n\r\n    setTimeout(() => {\r\n        const t = testimonials[index];\r\n\r\n        \/\/ Inject review\r\n        reviewTextEl.textContent = t.review;\r\n\r\n        \/\/ Generate stars dynamically\r\n        ratingEl.textContent = \"\u2605\".repeat(t.rating);\r\n\r\n        reviewTextEl.classList.remove('hidden');\r\n    }, 400);\r\n}\r\n\r\n        init();\r\n\r\n    <\/script>\r\n<\/div>"},"elements":[],"isInner":false,"widgetType":"html","elType":"widget"}],"isInner":true,"elType":"container"}],"isInner":false,"elType":"container"}],"page_settings":{"hide_title":"yes","eael_ext_toc_title":"Table of Contents"},"version":"0.4","title":"testimonials","type":"container"}